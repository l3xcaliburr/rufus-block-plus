{
  "manifest_version": 3,
  "name": "Amazon Rufus Blocker",
  "version": "1.0",
  "description": "Removes the Rufus AI chatbot from Amazon pages and reclaims your screen space.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.com.au/*",
        "*://*.amazon.in/*",
        "*://*.amazon.com.br/*"
      ],
      "css": ["rufus-nuke.css"],
      "js": ["rufus-nuke.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
